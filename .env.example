# Copy to .env and adjust. Used by the API server (server/index.js).

PORT=3001
NODE_ENV=development

# Change in production — used only if you add signed tokens later; sessions are random IDs in SQLite.
SESSION_SECRET=change-me-to-a-long-random-string

# Optional: absolute path to SQLite file (default: server/data/maaya.sqlite)
# DATABASE_PATH=C:\data\maaya.sqlite

# Google Sign-In (Gmail) — create an OAuth 2.0 "Web client" in Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins: http://localhost:5173
# Authorized redirect URIs: not required for GIS button (leave blank or use localhost)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
